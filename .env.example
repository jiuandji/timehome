# Environment Variables — TimeHome Realty
# Copy this file to .env.local and fill in the values

# ============================================
# Sanity CMS
# ============================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ============================================
# Cloudinary
# ============================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Mapbox
# ============================================
NEXT_PUBLIC_MAPBOX_TOKEN=

# ============================================
# Analytics (Plausible — GDPR-compliant)
# ============================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=timehomerealty.com

# ============================================
# Contact
# ============================================
NEXT_PUBLIC_WHATSAPP_NUMBER=34603379691
NEXT_PUBLIC_PHONE_NUMBER=+34 603 379 691
NEXT_PUBLIC_EMAIL=info@timehomerealty.com

# ============================================
# Site
# ============================================
NEXT_PUBLIC_SITE_URL=https://timehomerealty.com
NEXT_PUBLIC_DEFAULT_LOCALE=es
